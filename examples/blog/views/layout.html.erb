<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="utf-8">
  <title><%= @page_title %> — <%= @site_name %></title>
  <meta name="description" content="<%= @site_tagline %>">
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
           max-width: 720px; margin: 2em auto; padding: 0 1em; line-height: 1.6;
           color: #222; background: #fafafa; }
    nav { display: flex; gap: 1.5em; padding-bottom: 1em; border-bottom: 2px solid #333; margin-bottom: 2em; }
    nav a { color: #07c; text-decoration: none; font-weight: 600; }
    nav a.active { color: #c33; }
    h1 { margin: 0.5em 0 0.2em; }
    h1 a { color: inherit; text-decoration: none; }
    .meta { color: #888; font-size: 0.9em; margin-bottom: 1.5em; }
    .tag { display: inline-block; padding: 0.1em 0.6em; margin: 0 0.2em;
           background: #eef; color: #339; border-radius: 3px; font-size: 0.85em; }
    article { background: white; padding: 1.5em; border-radius: 6px;
              border: 1px solid #ddd; margin-bottom: 1.5em; }
    article header { margin-bottom: 1em; }
    .comment { background: #f8f8f8; padding: 0.8em 1em; border-left: 3px solid #ccc;
               margin: 0.5em 0; border-radius: 0 3px 3px 0; }
    .comment .meta { font-size: 0.85em; margin: 0 0 0.3em; }
    footer { margin-top: 3em; padding-top: 1em; border-top: 1px solid #ddd;
             color: #888; font-size: 0.85em; text-align: center; }
    .stats { display: flex; gap: 1em; color: #666; font-size: 0.9em; }
    .empty { color: #888; font-style: italic; }
  </style>
</head>
<body>
  <nav>
    <a href="/" class="<%= @active_nav == "home" ? "active" : "" %>">Home</a>
    <a href="/archives" class="<%= @active_nav == "archives" ? "active" : "" %>">Archives</a>
    <a href="/about" class="<%= @active_nav == "about" ? "active" : "" %>">About</a>
  </nav>

  <%= @content %>

  <footer>
    <p>© <%= @year %> <%= @site_name %>. Built with
    <a href="https://github.com/matz/spinel">Spinel</a> +
    <a href="https://github.com/gorin9/spnl-erb">spnl-erb</a>.</p>
    <p>Generated at <%= @generated_at %>. Total render: <%= @render_count %> view(s).</p>
  </footer>
</body>
</html>
